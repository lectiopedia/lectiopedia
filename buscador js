async function buscarLibros(){

const texto = document.getElementById("buscador").value.toLowerCase();

const contenedor = document.getElementById("catalogoLibros");

contenedor.innerHTML = "Buscando...";

const categorias = [

"psicologia",
"desarrollo_personal",
"marketing_y_multinivel",
"exito_y_negocio",
"historia",
"literatura",
"seduccion",
"tdah",
"nutricion_y_deporte",
"terror_suspenso_y_mas"

];

let resultados = [];

for(let categoria of categorias){

const respuesta = await fetch(`categorias/${categoria}.json`);

const data = await respuesta.json();

data.libros.forEach(libro => {

if(libro.toLowerCase().includes(texto)){

resultados.push(libro);

}

});

}

contenedor.innerHTML = "";

resultados.forEach(libro => {

const item = document.createElement("div");

item.className = "libro";

item.innerHTML = `
<img src="imagenes/libro.png" class="portadaLibro">
<p class="tituloLibro">${libro}</p>
`;

contenedor.appendChild(item);

});

}
